# ─────────────────────────────────────────────────────
# Konek — Environment Variables
# ─────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# Restart the dev server after editing .env.local.

# Supabase — public (safe for browser)
VITE_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
VITE_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase — secret (BACKEND ONLY, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Solana RPC endpoint
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.devnet.solana.com

# Midtrans server key (BACKEND ONLY)
MIDTRANS_SERVER_KEY=your-midtrans-server-key

# Treasury wallet address (public, receives SOL payments)
VITE_TREASURY_WALLET=YourSolanaWalletPublicKeyHere
