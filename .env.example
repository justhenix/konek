# ─────────────────────────────────────────────────────
# Konek — Environment Variables
# ─────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# Restart the dev server after editing .env.local.

# Supabase — public (safe for browser)
VITE_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
VITE_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase — secret (BACKEND ONLY, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Solana RPC endpoint
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.devnet.solana.com

# Backend quote signing (BACKEND ONLY, required for local payment testing)
# Generate a random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYMENT_QUOTE_SECRET=replace-with-a-long-random-secret

# Midtrans/Xendit server key (BACKEND ONLY) - Planned if we have a company
# MIDTRANS_SERVER_KEY=your-midtrans-server-key

# Treasury wallet address (public, receives SOL payments)
# Must be the same value for both VITE_ (frontend) and non-VITE_ (backend) keys.
VITE_TREASURY_WALLET=YourSolanaWalletPublicKeyHere
TREASURY_WALLET=YourSolanaWalletPublicKeyHere
